# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ============================================
# Virtual environments
# ============================================
.venv/
venv/
env/
ENV/

# ============================================
# Environment variables (секреты, API-ключи)
# ============================================
.env
.env.local
.env.production

# ============================================
# Data — держим только .gitkeep
# ============================================

data/raw/*
data/processed/*
data/annotations/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/annotations/.gitkeep

# ============================================
# ML модели и веса (часто > 100MB)
# ============================================
*.pt
*.pth
*.onnx
*.bin
*.safetensors
*.h5
*.hdf5
*.pkl
*.pickle
models_cache/

# ============================================
# Векторные индексы
# ============================================
*.faiss
*.index
qdrant_data/

# ============================================
# Jupyter Notebooks
# ============================================
.ipynb_checkpoints/
*.nbconvert.*

# ============================================
# IDE / редакторы
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ============================================
# Логи
# ============================================
*.log
logs/

# ============================================
# OS
# ============================================
Thumbs.db
.DS_Store

